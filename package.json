{
  "name": "@johntalton/http-util",
  "version": "6.1.0",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#util": "./src/headers/util/index.js"
  },
  "exports": {
    ".": "./src/headers/index.js",
    "./headers": "./src/headers/index.js",
    "./body": "./src/body.js",
    "./response": "./src/response/index.js",
    "./response/object": "./src/response/response.js",
    "./util": "./src/headers/util/index.js"
  },
  "files": [
    "src/*.js",
    "src/response/**/*.js",
    "src/headers/*.js",
    "src/headers/util/*.js"
  ],
  "scripts": {
    "lint": "biome check",
    "test": "node --test test/**/*.test.js",
    "coverage": "c8 --src src --check-coverage --lines 50 --functions 10 --branches 90 --statements 60 -r lcovonly -r text node --test test/**/*.test.js"
  },
  "repository": {
    "url": "https://github.com/johntalton/http-util"
  },
  "dependencies": {
    "@johntalton/sse-util": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "c8": "^11.0.0"
  },
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    }
  }
}
